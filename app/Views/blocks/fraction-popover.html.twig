{# Mostra o identificador da fração; ao clicar abre popover com tipologia, condóminos, permilagem e andar. #}
{# Parâmetros: identifier, owner_name, floor, stop_propagation (opcional), extra_class (opcional), typology (opcional), owner_names (opcional array), permillage (opcional) #}
{% set popover_parts = [] %}
{% if typology is defined and typology %}
  {% set popover_parts = popover_parts|merge(['<strong>Tipologia:</strong> ' ~ typology|e('html')]) %}
{% endif %}
{% if owner_names is defined and owner_names is iterable and owner_names|length > 0 %}
  {% set names_line = (owner_names|join(', '))|e('html') %}
  {% set popover_parts = popover_parts|merge(['<strong>Condóminos:</strong> ' ~ names_line]) %}
{% elseif owner_name is defined and owner_name %}
  {% set popover_parts = popover_parts|merge(['<strong>Condómino:</strong> ' ~ owner_name|e('html')]) %}
{% else %}
  {% set popover_parts = popover_parts|merge(['<strong>Condóminos:</strong> -']) %}
{% endif %}
{% if permillage is defined and permillage is not null and permillage is not same as('') %}
  {% set popover_parts = popover_parts|merge(['<strong>Permilagem:</strong> ' ~ (permillage|number_format(0, '', '')) ~ '‰']) %}
{% endif %}
{% if floor is defined and floor %}
  {% set popover_parts = popover_parts|merge(['<strong>Andar:</strong> ' ~ floor|e('html')]) %}
{% endif %}
{% set popover_content = popover_parts|join('<br>') %}
<span class="fraction-popover {{ extra_class|default('') }}"
      tabindex="0"
      role="button"
      style="cursor: pointer;"
      data-bs-toggle="popover"
      data-bs-trigger="focus"
      data-bs-placement="auto"
      data-bs-html="true"
      data-bs-content="{{ popover_content|e('html_attr') }}"
      {% if stop_propagation|default(false) %}onclick="event.stopPropagation()"{% endif %}>{{ identifier }}</span>
