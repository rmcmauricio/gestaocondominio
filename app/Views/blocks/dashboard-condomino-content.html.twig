{# Shared dashboard content for condomino (mobile + full). Uses dashboard_theme: 'mobile' or 'full' #}
{% set is_mobile = (dashboard_theme|default('full')) == 'mobile' %}
{% if is_mobile %}
    {% set url_fees = BASE_URL ~ 'm/fees' %}
    {% set url_notifications = BASE_URL ~ 'm/notifications' %}
    {% set url_messages = BASE_URL ~ 'm/messages' %}
    {% set url_receipts = BASE_URL ~ 'm/receipts' %}
    {% set url_reservations = BASE_URL ~ 'm/reservations' %}
    {% set url_occurrences = BASE_URL ~ 'm/occurrences' %}
{% else %}
    {% set url_fees = (first_condominium_id is defined and first_condominium_id) ? (BASE_URL ~ 'condominiums/' ~ first_condominium_id ~ '/fees') : (BASE_URL ~ 'receipts') %}
    {% set url_notifications = BASE_URL ~ 'notifications' %}
    {% set url_messages = user_condominiums is defined and user_condominiums|length > 0 ? (BASE_URL ~ 'condominiums/' ~ user_condominiums[0].condominium_id ~ '/messages') : '#' %}
    {% set url_receipts = BASE_URL ~ 'receipts' %}
    {% set url_reservations = user_condominiums is defined and user_condominiums|length > 0 ? (BASE_URL ~ 'condominiums/' ~ user_condominiums[0].condominium_id ~ '/reservations') : '#' %}
{% endif %}

{% if overdue_fees is defined and overdue_fees|length > 0 %}
    {% if is_mobile %}
    <section class="m-section">
        <div class="m-card m-alert-overdue">
            <h2 class="m-card-title"><i class="bi bi-exclamation-triangle-fill m-card-title-icon m-card-title-icon-danger"></i> Quotas em atraso</h2>
            <div class="m-overdue-header">
                <p class="m-overdue-total"><i class="bi bi-currency-euro"></i> Total em atraso: <strong>{{ total_overdue|number_format(2, ',', ' ') }} €</strong></p>
                {% if overdue_condominium_ibans is defined and overdue_condominium_ibans|length > 0 %}
                <button type="button" class="m-btn m-btn-iban" data-toggle="iban" aria-expanded="false" aria-controls="m-overdue-iban-block"><i class="bi bi-bank2"></i> Ver IBAN</button>
                {% endif %}
            </div>
            <div id="m-overdue-iban-block" class="m-overdue-iban-block" hidden>
                {% for row in overdue_condominium_ibans %}
                {% if row.iban %}
                <div class="m-overdue-iban-item">
                    {% if overdue_condominium_ibans|length > 1 %}<span class="m-overdue-iban-label">{{ row.condominium_name }}:</span>{% endif %}
                    <div class="m-overdue-iban-row">
                        <code class="m-overdue-iban-code">{{ row.iban }}</code>
                        <button type="button" class="m-btn-copy-iban" data-iban="{{ row.iban }}" title="Copiar IBAN" aria-label="Copiar IBAN"><i class="bi bi-clipboard"></i></button>
                    </div>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            <details class="m-overdue-details">
                <summary class="m-overdue-summary"><i class="bi bi-list-ul"></i> Ver lista de quotas em atraso ({{ overdue_fees|length }})</summary>
                <ul class="m-list">
                    {% for fee in overdue_fees %}
                    <li class="m-list-item"><i class="bi bi-currency-euro m-list-icon"></i> {{ fee.condominium_name }}{% if fee.fraction_identifier %} – {{ fee.fraction_identifier }}{% endif %}: {{ fee.period_display }} – {{ fee.remaining|number_format(2, ',', ' ') }} €</li>
                    {% endfor %}
                </ul>
            </details>
        </div>
    </section>
    {% else %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Quotas em atraso</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2"><i class="bi bi-currency-euro"></i> Total em atraso: <strong>{{ total_overdue|number_format(2, ',', ' ') }} €</strong></p>
                    {% if overdue_condominium_ibans is defined and overdue_condominium_ibans|length > 0 %}
                    <div class="mb-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary mb-2" data-bs-toggle="collapse" data-bs-target="#dashboard-overdue-iban"><i class="bi bi-bank2"></i> Ver IBAN</button>
                        <div id="dashboard-overdue-iban" class="collapse">
                            {% for row in overdue_condominium_ibans %}
                            {% if row.iban %}
                            <div class="d-flex align-items-center gap-2 mb-1">
                                {% if overdue_condominium_ibans|length > 1 %}<span class="text-muted small">{{ row.condominium_name }}:</span>{% endif %}
                                <code class="flex-grow-1">{{ row.iban }}</code>
                                <button type="button" class="btn btn-sm btn-outline-primary btn-copy-iban" data-iban="{{ row.iban }}" title="Copiar IBAN"><i class="bi bi-clipboard"></i></button>
                            </div>
                            {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    <details>
                        <summary class="text-primary cursor-pointer">Ver lista de quotas em atraso ({{ overdue_fees|length }})</summary>
                        <ul class="list-group list-group-flush mt-2">
                            {% for fee in overdue_fees %}
                            <li class="list-group-item">{{ fee.condominium_name }}{% if fee.fraction_identifier %} – {{ fee.fraction_identifier }}{% endif %}: {{ fee.period_display }} – {{ fee.remaining|number_format(2, ',', ' ') }} €</li>
                            {% endfor %}
                        </ul>
                    </details>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
{% endif %}

{% if pending_fees is defined and pending_fees|length > 0 %}
    {% if is_mobile %}
    <section class="m-section">
        <div class="m-card m-alert-pending">
            <h2 class="m-card-title"><i class="bi bi-clock-history m-card-title-icon m-card-title-icon-warning"></i> Quotas pendentes</h2>
            <p class="m-overdue-total"><i class="bi bi-currency-euro"></i> Total pendente: <strong>{{ total_pending|number_format(2, ',', ' ') }} €</strong></p>
            <details class="m-overdue-details">
                <summary class="m-overdue-summary"><i class="bi bi-list-ul"></i> Ver lista de quotas pendentes ({{ pending_fees|length }})</summary>
                <ul class="m-list">
                    {% for fee in pending_fees %}
                    <li class="m-list-item"><i class="bi bi-calendar-check m-list-icon"></i> {{ fee.condominium_name }}{% if fee.fraction_identifier %} – {{ fee.fraction_identifier }}{% endif %}: {{ fee.period_display }} – {{ fee.remaining|number_format(2, ',', ' ') }} € <span class="m-badge m-badge-due">Venc. {{ fee.due_date|date('d/m/Y') }}</span></li>
                    {% endfor %}
                </ul>
            </details>
            <a href="{{ BASE_URL }}condominiums/{{ pending_fees[0].condominium_id }}/fees" class="m-link-block"><i class="bi bi-wallet2"></i> Ver quotas e pagar</a>
        </div>
    </section>
    {% else %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-clock-history"></i> Quotas pendentes</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2"><i class="bi bi-currency-euro"></i> Total pendente: <strong>{{ total_pending|number_format(2, ',', ' ') }} €</strong></p>
                    <details>
                        <summary class="text-primary cursor-pointer">Ver lista de quotas pendentes ({{ pending_fees|length }})</summary>
                        <ul class="list-group list-group-flush mt-2">
                            {% for fee in pending_fees %}
                            <li class="list-group-item">{{ fee.condominium_name }}{% if fee.fraction_identifier %} – {{ fee.fraction_identifier }}{% endif %}: {{ fee.period_display }} – {{ fee.remaining|number_format(2, ',', ' ') }} € <span class="badge bg-secondary">Venc. {{ fee.due_date|date('d/m/Y') }}</span></li>
                            {% endfor %}
                        </ul>
                    </details>
                    <a href="{{ BASE_URL }}condominiums/{{ pending_fees[0].condominium_id }}/fees" class="btn btn-sm btn-primary mt-2"><i class="bi bi-wallet2"></i> Ver quotas e pagar</a>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
{% endif %}

{% if (overdue_fees is not defined or overdue_fees|length == 0) and (pending_fees is not defined or pending_fees|length == 0) %}
    {% if is_mobile %}
    <section class="m-section">
        <div class="m-card m-card-empty">
            <h2 class="m-card-title"><i class="bi bi-currency-euro m-card-title-icon m-card-title-icon-muted"></i> Quotas por liquidar</h2>
            <p class="m-empty"><i class="bi bi-check-circle"></i> Não tem quotas por liquidar.</p>
            <a href="{{ url_fees }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver quotas</a>
        </div>
    </section>
    {% else %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-muted"><i class="bi bi-currency-euro"></i> Quotas por liquidar</h5>
                    <p class="text-muted mb-0"><i class="bi bi-check-circle text-success"></i> Não tem quotas por liquidar.</p>
                    {% if first_condominium_id %}<a href="{{ url_fees }}" class="btn btn-sm btn-outline-primary mt-2">Ver quotas</a>{% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}
{% endif %}

{% if fraction_balances is defined and fraction_balances|length > 0 %}
    {% if is_mobile %}
    <section class="m-section">
        <div class="m-card m-alert-balance">
            <h2 class="m-card-title"><i class="bi bi-wallet2 m-card-title-icon m-card-title-icon-success"></i> Saldo em conta</h2>
            <ul class="m-list">
                {% for row in fraction_balances %}
                <li class="m-list-item"><i class="bi bi-piggy-bank m-list-icon"></i> {{ row.condominium_name }}{% if row.fraction_identifier %} – {{ row.fraction_identifier }}{% endif %}: {{ row.balance|number_format(2, ',', ' ') }} €</li>
                {% endfor %}
            </ul>
        </div>
    </section>
    {% else %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-wallet2"></i> Saldo em conta</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        {% for row in fraction_balances %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-piggy-bank text-success me-2"></i>{{ row.condominium_name }}{% if row.fraction_identifier %} – {{ row.fraction_identifier }}{% endif %}</span>
                            <strong class="text-success">€{{ row.balance|number_format(2, ',', ' ') }}</strong>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
{% endif %}

{# Notifications #}
{% if is_mobile %}
    {% if unread_notifications is defined and unread_notifications|length > 0 %}
    <section class="m-section">
        <h2 class="m-card-title"><i class="bi bi-bell-fill m-card-title-icon m-card-title-icon-primary"></i> Notificações não lidas</h2>
        <div class="m-notifications-list">
            {% for notification in unread_notifications %}
                {% set notification_icon = 'bi-bell' %}
                {% set notification_color_class = 'm-notif-primary' %}
                {% if notification.type == 'occurrence' %}{% set notification_icon = 'bi-exclamation-triangle' %}{% set notification_color_class = 'm-notif-warning' %}
                {% elseif notification.type == 'assembly' %}{% set notification_icon = 'bi-people' %}{% set notification_color_class = 'm-notif-info' %}
                {% elseif notification.type == 'fee_overdue' %}{% set notification_icon = 'bi-currency-euro' %}{% set notification_color_class = 'm-notif-danger' %}
                {% elseif notification.type == 'message' or notification.source_type == 'message' %}{% set notification_icon = 'bi-envelope' %}{% set notification_color_class = 'm-notif-primary' %}
                {% elseif notification.type == 'occurrence_comment' %}{% set notification_icon = 'bi-chat' %}{% set notification_color_class = 'm-notif-success' %}
                {% endif %}
                <div class="m-card m-notification-card m-notification-unread {{ notification_color_class }}">
                    <div class="m-notification-inner">
                        <div class="m-notification-icon {{ notification_color_class }}"><i class="bi {{ notification_icon }}"></i></div>
                        <div class="m-notification-body">
                            <div class="m-notification-row">
                                <h2 class="m-notification-title m-notification-title-unread">{{ notification.title }}</h2>
                                {% if notification.type == 'occurrence' and notification.priority %}
                                <span class="m-badge m-priority-{{ notification.priority|default('medium') }}">{{ notification.priority == 'urgent' ? 'Urgente' : (notification.priority == 'high' ? 'Alta' : (notification.priority == 'medium' ? 'Média' : 'Baixa')) }}</span>
                                {% endif %}
                            </div>
                            <p class="m-notification-message">{{ notification.message }}</p>
                            <div class="m-notification-meta"><i class="bi bi-clock"></i> {% set created_at = notification.created_at|date('U') %}{% set now = 'now'|date('U') %}{% set diff = now - created_at %}{% if diff < 60 %}agora{% elseif diff < 3600 %}há {{ (diff / 60)|round }} minutos{% elseif diff < 86400 %}há {{ (diff / 3600)|round }} horas{% elseif diff < 604800 %}há {{ (diff / 86400)|round }} dias{% elseif diff < 2592000 %}há {{ (diff / 604800)|round }} semanas{% else %}há {{ (diff / 2592000)|round }} meses{% endif %}</div>
                            <div class="m-notification-actions">
                                <a href="{{ BASE_URL }}m/notifications/show?id={{ notification.id|e('url') }}" class="m-btn m-btn-sm m-btn-ver-mais" title="Ver mais"><i class="bi bi-envelope"></i> Ver mais</a>
                                <form method="POST" action="{{ BASE_URL }}m/notifications/{{ notification.id|e('url') }}/mark-read" class="m-notification-form-inline"><button type="submit" class="m-btn m-btn-sm m-btn-success" title="Marcar como lida"><i class="bi bi-check"></i></button></form>
                                {% if notification.source_type == 'notification' %}<form method="POST" action="{{ BASE_URL }}m/notifications/{{ notification.id|e('url') }}/delete" class="m-notification-form-inline" data-confirm="Eliminar esta notificação?"><button type="submit" class="m-btn m-btn-sm m-btn-danger" title="Eliminar"><i class="bi bi-trash"></i></button></form>{% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <a href="{{ url_notifications }}" class="m-link-block m-notifications-ver-mais"><i class="bi bi-chevron-right"></i> Ver mais</a>
    </section>
    {% else %}
    <section class="m-section">
        <div class="m-card m-card-empty">
            <h2 class="m-card-title"><i class="bi bi-bell m-card-title-icon m-card-title-icon-muted"></i> Notificações</h2>
            <p class="m-empty"><i class="bi bi-check-circle"></i> Não tem notificações não lidas.</p>
            <a href="{{ url_notifications }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver notificações</a>
        </div>
    </section>
    {% endif %}
{% else %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center {{ unread_notifications is defined and unread_notifications|length > 0 ? 'bg-primary text-white' : '' }}">
                    <h5 class="mb-0"><i class="bi {{ unread_notifications is defined and unread_notifications|length > 0 ? 'bi-bell-fill' : 'bi-bell' }}"></i> Notificações não lidas</h5>
                    <a href="{{ url_notifications }}" class="btn btn-sm {{ unread_notifications is defined and unread_notifications|length > 0 ? 'btn-light' : 'btn-outline-primary' }}">Ver notificações</a>
                </div>
                <div class="card-body">
                    {% if unread_notifications is defined and unread_notifications|length > 0 %}
                        {% for notification in unread_notifications %}
                            {% set notification_icon = 'bi-bell' %}{% set notification_color = 'primary' %}
                            {% if notification.type == 'occurrence' %}{% set notification_icon = 'bi-exclamation-triangle' %}{% set notification_color = 'warning' %}
                            {% elseif notification.type == 'assembly' %}{% set notification_icon = 'bi-people' %}{% set notification_color = 'info' %}
                            {% elseif notification.type == 'fee_overdue' %}{% set notification_icon = 'bi-currency-euro' %}{% set notification_color = 'danger' %}
                            {% elseif notification.type == 'message' or notification.source_type == 'message' %}{% set notification_icon = 'bi-envelope' %}{% set notification_color = 'primary' %}
                            {% elseif notification.type == 'occurrence_comment' %}{% set notification_icon = 'bi-chat' %}{% set notification_color = 'success' %}
                            {% endif %}
                            {% set notif_link = notification.link is defined and notification.link ? (notification.link|slice(0, 4) == 'http' or (BASE_URL|length > 0 and notification.link|slice(0, BASE_URL|length) == BASE_URL) ? notification.link : BASE_URL ~ notification.link|trim('/')) : '' %}
                            {% if notif_link %}<a href="{{ notif_link }}" class="text-decoration-none" style="color:inherit;">{% endif %}
                            <div class="card mb-2 shadow-sm {% if not notification.is_read %}border-start border-2 border-{{ notification_color }}{% endif %}">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-start gap-2">
                                        <i class="bi {{ notification_icon }} text-{{ notification_color }}"></i>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0 {% if not notification.is_read %}fw-bold{% endif %}">{{ notification.title }}</h6>
                                            {% if notification.type == 'occurrence' and notification.priority %}<span class="badge bg-{{ notification.priority == 'urgent' ? 'danger' : (notification.priority == 'high' ? 'warning' : 'info') }}">{{ notification.priority == 'urgent' ? 'Urgente' : (notification.priority == 'high' ? 'Alta' : 'Média') }}</span>{% endif %}
                                            <p class="mb-0 text-muted small">{{ notification.message }}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {% if notif_link %}</a>{% endif %}
                        {% endfor %}
                    {% else %}
                        <p class="text-muted mb-0"><i class="bi bi-check-circle text-success me-1"></i>Não tem notificações não lidas.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endif %}

{# Messages #}
{% if is_mobile %}
    {% if unread_messages_count is defined and unread_messages_count > 0 %}
    <section class="m-section">
        <h2 class="m-card-title"><i class="bi bi-envelope-fill m-card-title-icon m-card-title-icon-primary"></i> Mensagens por ler</h2>
        {% if unread_messages is defined and unread_messages|length > 0 %}
        <div class="m-notifications-list">
            {% for message in unread_messages %}
            <div class="m-card m-notification-card m-notification-unread m-notif-primary">
                <div class="m-notification-inner">
                    <div class="m-notification-icon m-notif-primary"><i class="bi bi-envelope"></i></div>
                    <div class="m-notification-body">
                        <div class="m-notification-row"><h2 class="m-notification-title m-notification-title-unread">{{ message.subject|default('Mensagem') }}</h2></div>
                        <p class="m-notification-message">{{ message.message|striptags|slice(0, 120) }}{% if message.message|striptags|length > 120 %}...{% endif %}</p>
                        <div class="m-notification-meta"><i class="bi bi-person"></i> {{ message.sender_name|default('Sistema') }}{% if message.condominium_name %} · {{ message.condominium_name }}{% endif %}</div>
                        <div class="m-notification-actions">
                            <a href="{{ BASE_URL }}m/messages/show?id={{ message.id }}" class="m-btn m-btn-sm m-btn-ver-mais" title="Ver mais"><i class="bi bi-envelope-open"></i> Ver mais</a>
                            <form method="POST" action="{{ BASE_URL }}m/messages/{{ message.id }}/mark-read" class="m-notification-form-inline"><button type="submit" class="m-btn m-btn-sm m-btn-success" title="Marcar como lida"><i class="bi bi-check"></i></button></form>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <p class="m-card-body">{{ unread_messages_count }} mensagem(ns) por ler.</p>
        {% endif %}
        <a href="{{ url_messages }}" class="m-link-block m-notifications-ver-mais"><i class="bi bi-chevron-right"></i> Ver mais</a>
    </section>
    {% else %}
    <section class="m-section">
        <div class="m-card m-card-empty">
            <h2 class="m-card-title"><i class="bi bi-envelope m-card-title-icon m-card-title-icon-muted"></i> Mensagens</h2>
            <p class="m-empty"><i class="bi bi-check-circle"></i> Não tem mensagens por ler.</p>
            <a href="{{ url_messages }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver mensagens</a>
        </div>
    </section>
    {% endif %}
{% else %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center {{ unread_messages_count is defined and unread_messages_count > 0 ? 'bg-primary text-white' : '' }}">
                    <h5 class="mb-0"><i class="bi {{ unread_messages_count is defined and unread_messages_count > 0 ? 'bi-envelope-fill' : 'bi-envelope' }}"></i> Mensagens por ler</h5>
                    <a href="{{ url_messages }}" class="btn btn-sm {{ unread_messages_count is defined and unread_messages_count > 0 ? 'btn-light' : 'btn-outline-primary' }}">Ver mensagens</a>
                </div>
                <div class="card-body">
                    {% if unread_messages is defined and unread_messages|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for message in unread_messages %}
                            <a href="{{ BASE_URL }}condominiums/{{ message.condominium_id }}/messages/{{ message.id }}" class="list-group-item list-group-item-action">
                                <h6 class="mb-1">{{ message.subject|default('Mensagem') }}</h6>
                                <p class="mb-1 text-muted small">{{ message.message|striptags|slice(0, 120) }}{% if message.message|striptags|length > 120 %}...{% endif %}</p>
                                <small class="text-muted"><i class="bi bi-person"></i> {{ message.sender_name|default('Sistema') }}{% if message.condominium_name %} · {{ message.condominium_name }}{% endif %}</small>
                            </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted mb-0"><i class="bi bi-check-circle text-success me-1"></i>Não tem mensagens por ler.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endif %}

{# Últimos recibos #}
{% if is_mobile %}
<section class="m-section">
    <div class="m-card m-alert-receipts">
        <h2 class="m-card-title"><i class="bi bi-receipt m-card-title-icon m-card-title-icon-muted"></i> Últimos recibos</h2>
        {% if last_receipts is defined and last_receipts|length > 0 %}
        <ul class="m-list">
            {% for r in last_receipts %}
            <li class="m-list-item">
                <i class="bi bi-file-earmark-pdf m-list-icon"></i> {{ r.condominium_name|default('') }} – {{ r.period_display }}
                <a href="{{ BASE_URL }}condominiums/{{ r.condominium_id }}/receipts/{{ r.id }}/download" class="m-link-block"><i class="bi bi-download"></i> Descarregar</a>
            </li>
            {% endfor %}
        </ul>
        <a href="{{ url_receipts }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver todos os recibos</a>
        {% else %}
        <p class="m-empty"><i class="bi bi-inbox"></i> Sem recibos.</p>
        <a href="{{ url_receipts }}" class="m-link-block"><i class="bi bi-receipt"></i> Os meus recibos</a>
        {% endif %}
    </div>
</section>
{% else %}
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-receipt"></i> Últimos recibos</h5>
                <a href="{{ url_receipts }}" class="btn btn-sm btn-outline-primary">Ver todos os recibos</a>
            </div>
            <div class="card-body">
                {% if last_receipts is defined and last_receipts|length > 0 %}
                    <ul class="list-group list-group-flush">
                        {% for r in last_receipts %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-file-earmark-pdf text-danger me-2"></i>{{ r.condominium_name|default('') }} – {{ r.period_display }}</span>
                            <a href="{{ BASE_URL }}condominiums/{{ r.condominium_id }}/receipts/{{ r.id }}/download" class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i> Descarregar</a>
                        </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-muted mb-0"><i class="bi bi-inbox me-1"></i>Sem recibos.</p>
                    <a href="{{ url_receipts }}" class="btn btn-sm btn-primary mt-2"><i class="bi bi-receipt"></i> Os meus recibos</a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Full only: As minhas reservas + As minhas ocorrências #}
{% if not is_mobile and (user_reservations is defined or user_occurrences is defined or (user_condominiums is defined and user_condominiums|length > 0)) %}
<div class="row mb-4">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-calendar-check"></i> As Minhas Reservas</h5>
                {% if user_condominiums is defined and user_condominiums|length > 0 %}
                <a href="{{ BASE_URL }}condominiums/{{ user_condominiums[0].condominium_id }}/reservations" class="btn btn-sm btn-outline-primary">Ver Todas <i class="bi bi-arrow-right"></i></a>
                {% endif %}
            </div>
            <div class="card-body">
                {% if user_reservations is defined and user_reservations|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for reservation in user_reservations %}
                        <a href="{{ BASE_URL }}condominiums/{{ reservation.condominium_id }}/reservations" class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">{{ reservation.space_name }}</h6>
                                <span class="badge {% if reservation.status == 'approved' %}bg-success{% elseif reservation.status == 'pending' %}bg-warning{% elseif reservation.status == 'rejected' %}bg-danger{% else %}bg-secondary{% endif %}">{{ reservation.status|title }}</span>
                            </div>
                            <p class="mb-1 text-muted small"><i class="bi bi-calendar"></i> {{ reservation.start_date|date('d/m/Y H:i') }} - {{ reservation.end_date|date('H:i') }}</p>
                            <small class="text-muted"><i class="bi bi-building"></i> {{ reservation.condominium_name }}{% if reservation.fraction_identifier %} | {{ reservation.fraction_identifier }}{% endif %}</small>
                        </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted mb-0">Nenhuma reserva encontrada.</p>
                    {% if user_condominiums is defined and user_condominiums|length > 0 %}
                    <a href="{{ BASE_URL }}condominiums/{{ user_condominiums[0].condominium_id }}/reservations/create" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-circle"></i> Criar Reserva</a>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> As Minhas Ocorrências</h5>
                {% if user_condominiums is defined and user_condominiums|length > 0 %}
                <a href="{{ BASE_URL }}condominiums/{{ user_condominiums[0].condominium_id }}/occurrences" class="btn btn-sm btn-outline-primary">Ver Todas <i class="bi bi-arrow-right"></i></a>
                {% endif %}
            </div>
            <div class="card-body">
                {% if user_occurrences is defined and user_occurrences|length > 0 %}
                    <div class="list-group list-group-flush">
                        {% for occurrence in user_occurrences %}
                        <a href="{{ BASE_URL }}condominiums/{{ occurrence.condominium_id }}/occurrences/{{ occurrence.id }}" class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1">{{ occurrence.title }}</h6>
                                <span class="badge {% if occurrence.status == 'resolved' %}bg-success{% elseif occurrence.status == 'in_progress' %}bg-info{% elseif occurrence.priority == 'high' %}bg-danger{% elseif occurrence.priority == 'medium' %}bg-warning{% else %}bg-secondary{% endif %}">{{ occurrence.status|title }}</span>
                            </div>
                            <p class="mb-1 text-muted small">{{ occurrence.description|slice(0, 80) }}{% if occurrence.description|length > 80 %}...{% endif %}</p>
                            <small class="text-muted"><i class="bi bi-building"></i> {{ occurrence.condominium_name }}{% if occurrence.fraction_identifier %} | {{ occurrence.fraction_identifier }}{% endif %} | <i class="bi bi-clock"></i> {{ occurrence.created_at|date('d/m/Y') }}</small>
                        </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-muted mb-0">Nenhuma ocorrência encontrada.</p>
                    {% if user_condominiums is defined and user_condominiums|length > 0 %}
                    <a href="{{ BASE_URL }}condominiums/{{ user_condominiums[0].condominium_id }}/occurrences/create" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-circle"></i> Criar Ocorrência</a>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Mobile: As minhas reservas + As minhas ocorrências (mesmo conteúdo que full) #}
{% if is_mobile and (user_reservations is defined or user_occurrences is defined or (user_condominiums is defined and user_condominiums|length > 0)) %}
<section class="m-section">
    <div class="m-card">
        <h2 class="m-card-title"><i class="bi bi-calendar-check m-card-title-icon m-card-title-icon-info"></i> As Minhas Reservas</h2>
        <a href="{{ url_reservations }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver Todas</a>
        {% if user_reservations is defined and user_reservations|length > 0 %}
            <ul class="m-list">
                {% for reservation in user_reservations %}
                <li class="m-list-item">
                    <a href="{{ BASE_URL }}condominiums/{{ reservation.condominium_id }}/reservations" class="text-decoration-none">{{ reservation.space_name }} – {{ reservation.start_date|date('d/m/Y H:i') }} <span class="badge {% if reservation.status == 'approved' %}bg-success{% elseif reservation.status == 'pending' %}bg-warning{% else %}bg-secondary{% endif %}">{{ reservation.status|title }}</span></a>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="text-muted mb-2">Nenhuma reserva encontrada.</p>
            {% if first_condominium_id is defined and first_condominium_id %}
            <a href="{{ BASE_URL }}condominiums/{{ first_condominium_id }}/reservations/create" class="m-btn m-btn-primary"><i class="bi bi-plus-circle"></i> Criar Reserva</a>
            {% endif %}
        {% endif %}
    </div>
</section>
<section class="m-section">
    <div class="m-card">
        <h2 class="m-card-title"><i class="bi bi-exclamation-triangle m-card-title-icon m-card-title-icon-warning"></i> As Minhas Ocorrências</h2>
        <a href="{{ url_occurrences }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver Todas</a>
        {% if user_occurrences is defined and user_occurrences|length > 0 %}
            <ul class="m-list">
                {% for occurrence in user_occurrences %}
                <li class="m-list-item">
                    <a href="{{ BASE_URL }}condominiums/{{ occurrence.condominium_id }}/occurrences/{{ occurrence.id }}" class="text-decoration-none">{{ occurrence.title }} <span class="badge {% if occurrence.status == 'resolved' %}bg-success{% elseif occurrence.status == 'in_progress' %}bg-info{% else %}bg-secondary{% endif %}">{{ occurrence.status|title }}</span></a>
                </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="text-muted mb-2">Nenhuma ocorrência encontrada.</p>
            {% if first_condominium_id is defined and first_condominium_id %}
            <a href="{{ BASE_URL }}condominiums/{{ first_condominium_id }}/occurrences/create" class="m-btn m-btn-primary"><i class="bi bi-plus-circle"></i> Criar Ocorrência</a>
            {% endif %}
        {% endif %}
    </div>
</section>
{% endif %}

{# Mobile: future reservations (lista extra quando há reservas futuras) #}
{% if is_mobile and future_reservations is defined and future_reservations|length > 0 %}
<section class="m-section">
    <div class="m-card">
        <h2 class="m-card-title"><i class="bi bi-calendar-event m-card-title-icon m-card-title-icon-info"></i> Marcações de espaços (futuras)</h2>
        <ul class="m-list">
            {% for res in future_reservations %}
            <li class="m-list-item"><i class="bi bi-calendar3 m-list-icon"></i> {{ res.space_name }} – {{ res.start_date|date('d/m/Y') }} – {{ res.condominium_name }}</li>
            {% endfor %}
        </ul>
        <a href="{{ url_reservations }}" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver reservas</a>
    </div>
</section>
{% endif %}

{# Reportar ocorrência #}
{% if first_condominium_id is defined and first_condominium_id %}
    {% if is_mobile %}
    <section class="m-section">
        <a href="{{ BASE_URL }}condominiums/{{ first_condominium_id }}/occurrences/create" class="m-btn-report"><i class="bi bi-plus-circle"></i> Reportar ocorrência</a>
    </section>
    {% else %}
    <div class="row mb-4">
        <div class="col-12">
            <a href="{{ BASE_URL }}condominiums/{{ first_condominium_id }}/occurrences/create" class="btn btn-primary btn-lg"><i class="bi bi-plus-circle me-2"></i> Reportar ocorrência</a>
        </div>
    </div>
    {% endif %}
{% endif %}
