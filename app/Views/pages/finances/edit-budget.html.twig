<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Editar Orçamento</h4>
                    <small>{{ condominium.name }} - {{ budget.year }}</small>
                </div>
                <div class="card-body p-4">
                    {% if error %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ error }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    {% endif %}

                    {% if budget.status == 'approved' or budget.status == 'active' %}
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Este orçamento está aprovado. Alterações podem afetar quotas já geradas.
                    </div>
                    {% endif %}

                    <form method="POST" action="{{ BASE_URL }}condominiums/{{ condominium.id }}/budgets/{{ budget.id }}">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        <input type="hidden" name="_method" value="PUT">

                        <div class="mb-4">
                            <h5 class="mb-3">Receitas Previstas</h5>
                            <div id="revenueItems">
                                {% set revenue_count = 0 %}
                                {% for item in budget_items %}
                                    {% if item.category|slice(0, 8) == 'Receita:' %}
                                    {% set category_name = item.category|replace({'Receita: ': ''})|trim %}
                                    <div class="revenue-item mb-3 p-3 border rounded bg-light">
                                        <div class="row g-3">
                                            <div class="col-md-12">
                                                <label class="form-label small text-muted">Descrição</label>
                                                <input type="text" class="form-control" name="revenue_items[{{ revenue_count }}][description]" value="{{ item.description|e }}" placeholder="Ex: Quotas mensais" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small text-muted">Categoria</label>
                                                <select class="form-select budget-revenue-category" name="revenue_items[{{ revenue_count }}][category]" required>
                                                    <option value="">Selecione...</option>
                                                    {% for cat in revenue_categories|default([]) %}
                                                    <option value="{{ cat.name|e('html_attr') }}" {% if category_name == cat.name %}selected="selected"{% endif %}>{{ cat.name }}</option>
                                                    {% endfor %}
                                                    {% if category_name and category_name not in revenue_category_names|default([]) %}
                                                    <option value="{{ category_name|e('html_attr') }}" selected="selected">{{ category_name }}</option>
                                                    {% endif %}
                                                    <option value="__new__">+ Criar nova...</option>
                                                </select>
                                            </div>
                                            <div class="col-md-5">
                                                <label class="form-label small text-muted">Valor (€)</label>
                                                <div class="input-group">
                                                    <span class="input-group-text">€</span>
                                                    <input type="number" class="form-control revenue-amount" name="revenue_items[{{ revenue_count }}][amount]" step="0.01" min="0" value="{{ item.amount }}" placeholder="0.00" required>
                                                </div>
                                            </div>
                                            <div class="col-md-1 d-flex align-items-end">
                                                <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeItem(this)" title="Remover">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    {% set revenue_count = revenue_count + 1 %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-success" onclick="addRevenueItem()">
                                <i class="bi bi-plus-circle"></i> Adicionar Receita
                            </button>
                            <div class="mt-3">
                                <strong>Total Receitas: €<span id="totalRevenue">0.00</span></strong>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="mb-4">
                            <h5 class="mb-3">Despesas Previstas</h5>
                            <div id="expenseItems">
                                {% set expense_count = 0 %}
                                {% for item in budget_items %}
                                    {% if item.category|slice(0, 8) == 'Despesa:' %}
                                    {% set category_name = item.category|replace({'Despesa: ': ''})|trim %}
                                    <div class="expense-item mb-3 p-3 border rounded bg-light">
                                        <div class="row g-3">
                                            <div class="col-md-12">
                                                <label class="form-label small text-muted">Descrição</label>
                                                <input type="text" class="form-control" name="expense_items[{{ expense_count }}][description]" value="{{ item.description|e }}" placeholder="Ex: Limpeza mensal" required>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small text-muted">Categoria</label>
                                                <select class="form-select budget-expense-category" name="expense_items[{{ expense_count }}][category]" required>
                                                    <option value="">Selecione...</option>
                                                    {% for cat in expense_categories|default([]) %}
                                                    <option value="{{ cat.name|e('html_attr') }}" {% if category_name == cat.name %}selected="selected"{% endif %}>{{ cat.name }}</option>
                                                    {% endfor %}
                                                    {% if category_name and category_name not in expense_category_names|default([]) %}
                                                    <option value="{{ category_name|e('html_attr') }}" selected="selected">{{ category_name }}</option>
                                                    {% endif %}
                                                    <option value="__new__">+ Criar nova...</option>
                                                </select>
                                            </div>
                                            <div class="col-md-5">
                                                <label class="form-label small text-muted">Valor (€)</label>
                                                <div class="input-group">
                                                    <span class="input-group-text">€</span>
                                                    <input type="number" class="form-control expense-amount" name="expense_items[{{ expense_count }}][amount]" step="0.01" min="0" value="{{ item.amount }}" placeholder="0.00" required>
                                                </div>
                                            </div>
                                            <div class="col-md-1 d-flex align-items-end">
                                                <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeItem(this)" title="Remover">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    {% set expense_count = expense_count + 1 %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="addExpenseItem()">
                                <i class="bi bi-plus-circle"></i> Adicionar Despesa
                            </button>
                            <div class="mt-3">
                                <strong>Total Despesas: €<span id="totalExpenses">0.00</span></strong>
                            </div>
                        </div>

                        <hr>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="alert alert-info">
                                    <strong>Saldo Previsto:</strong> €<span id="balance">0.00</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="notes" class="form-label">Notas</label>
                                    <textarea class="form-control" id="notes" name="notes" rows="3">{{ budget.notes }}</textarea>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/budgets/{{ budget.id }}" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">Guardar Alterações</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
var BUDGET_REVENUE_CATEGORIES = {{ revenue_category_names|default([])|json_encode|raw }};
var BUDGET_EXPENSE_CATEGORIES = {{ expense_category_names|default([])|json_encode|raw }};
if (!Array.isArray(BUDGET_REVENUE_CATEGORIES) || !BUDGET_REVENUE_CATEGORIES.length) BUDGET_REVENUE_CATEGORIES = ['Quotas', 'Multas', 'Juros', 'Outras Receitas'];
if (!Array.isArray(BUDGET_EXPENSE_CATEGORIES) || !BUDGET_EXPENSE_CATEGORIES.length) BUDGET_EXPENSE_CATEGORIES = ['Limpeza', 'Manutenção', 'Segurança', 'Energia', 'Água', 'Seguros', 'Administração', 'Outras Despesas'];

// Initialize indices based on existing items
{% set revenue_items_count = 0 %}
{% set expense_items_count = 0 %}
{% for item in budget_items %}
    {% if item.category|slice(0, 8) == 'Receita:' %}
        {% set revenue_items_count = revenue_items_count + 1 %}
    {% endif %}
    {% if item.category|slice(0, 8) == 'Despesa:' %}
        {% set expense_items_count = expense_items_count + 1 %}
    {% endif %}
{% endfor %}
let revenueIndex = {{ revenue_items_count }};
let expenseIndex = {{ expense_items_count }};

function addBudgetCategoryOption(selectEl, name, isNew) {
    var opt = document.createElement('option');
    opt.value = name;
    opt.textContent = name;
    var newOpt = selectEl.querySelector('option[value="__new__"]');
    if (newOpt) selectEl.insertBefore(opt, newOpt);
    else selectEl.appendChild(opt);
    if (isNew) selectEl.value = name;
}

function attachBudgetCategoryCreateListeners() {
    document.querySelectorAll('.budget-expense-category, .budget-revenue-category').forEach(function(sel) {
        if (sel.hasAttribute('data-budget-cat-listener')) return;
        sel.setAttribute('data-budget-cat-listener', '1');
        sel.addEventListener('change', function() {
            var v = this.value;
            var selectEl = this;
            if (v !== '__new__') { selectEl.dataset.prevBudgetCat = v; return; }
            if (typeof window.openNewCategoryModal === 'function') {
                window.openNewCategoryModal(function(name) {
                    addBudgetCategoryOption(selectEl, name, true);
                    if (selectEl.classList.contains('budget-expense-category') && BUDGET_EXPENSE_CATEGORIES.indexOf(name) === -1) BUDGET_EXPENSE_CATEGORIES.push(name);
                    if (selectEl.classList.contains('budget-revenue-category') && BUDGET_REVENUE_CATEGORIES.indexOf(name) === -1) BUDGET_REVENUE_CATEGORIES.push(name);
                });
            }
            selectEl.value = selectEl.dataset.prevBudgetCat || '';
        });
    });
}

function addRevenueItem() {
    var catOpts = '<option value="">Selecione...</option>';
    BUDGET_REVENUE_CATEGORIES.forEach(function(n) { catOpts += '<option value="' + (n.replace(/"/g, '&quot;')) + '">' + (n.replace(/</g, '&lt;')) + '</option>'; });
    catOpts += '<option value="__new__">+ Criar nova...</option>';
    const html = `
        <div class="revenue-item mb-3 p-3 border rounded bg-light">
            <div class="row g-3">
                <div class="col-md-12">
                    <label class="form-label small text-muted">Descrição</label>
                    <input type="text" class="form-control" name="revenue_items[${revenueIndex}][description]" placeholder="Ex: Quotas mensais" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted">Categoria</label>
                    <select class="form-select budget-revenue-category" name="revenue_items[${revenueIndex}][category]" required>
                        ${catOpts}
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label small text-muted">Valor (€)</label>
                    <div class="input-group">
                        <span class="input-group-text">€</span>
                        <input type="number" class="form-control revenue-amount" name="revenue_items[${revenueIndex}][amount]" step="0.01" min="0" placeholder="0.00" required>
                    </div>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeItem(this)" title="Remover">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;
    document.getElementById('revenueItems').insertAdjacentHTML('beforeend', html);
    revenueIndex++;
    attachCalculators();
    attachBudgetCategoryCreateListeners();
    calculateTotals();
}

function addExpenseItem() {
    var catOpts = '<option value="">Selecione...</option>';
    BUDGET_EXPENSE_CATEGORIES.forEach(function(n) { catOpts += '<option value="' + (n.replace(/"/g, '&quot;')) + '">' + (n.replace(/</g, '&lt;')) + '</option>'; });
    catOpts += '<option value="__new__">+ Criar nova...</option>';
    const html = `
        <div class="expense-item mb-3 p-3 border rounded bg-light">
            <div class="row g-3">
                <div class="col-md-12">
                    <label class="form-label small text-muted">Descrição</label>
                    <input type="text" class="form-control" name="expense_items[${expenseIndex}][description]" placeholder="Ex: Limpeza mensal" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted">Categoria</label>
                    <select class="form-select budget-expense-category" name="expense_items[${expenseIndex}][category]" required>
                        ${catOpts}
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label small text-muted">Valor (€)</label>
                    <div class="input-group">
                        <span class="input-group-text">€</span>
                        <input type="number" class="form-control expense-amount" name="expense_items[${expenseIndex}][amount]" step="0.01" min="0" placeholder="0.00" required>
                    </div>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="button" class="btn btn-sm btn-outline-danger w-100" onclick="removeItem(this)" title="Remover">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>
        </div>
    `;
    document.getElementById('expenseItems').insertAdjacentHTML('beforeend', html);
    expenseIndex++;
    attachCalculators();
    attachBudgetCategoryCreateListeners();
    calculateTotals();
}

function removeItem(button) {
    button.closest('.revenue-item, .expense-item').remove();
    calculateTotals();
}

function calculateTotals() {
    let totalRevenue = 0;
    let totalExpenses = 0;

    // Use class selectors for better performance
    document.querySelectorAll('#revenueItems .revenue-amount').forEach(input => {
        totalRevenue += parseFloat(input.value) || 0;
    });

    document.querySelectorAll('#expenseItems .expense-amount').forEach(input => {
        totalExpenses += parseFloat(input.value) || 0;
    });

    document.getElementById('totalRevenue').textContent = totalRevenue.toFixed(2);
    document.getElementById('totalExpenses').textContent = totalExpenses.toFixed(2);
    document.getElementById('balance').textContent = (totalRevenue - totalExpenses).toFixed(2);
}

function attachCalculators() {
    // Add listeners to all amount inputs (avoid duplicates)
    document.querySelectorAll('#revenueItems .revenue-amount, #expenseItems .expense-amount').forEach(input => {
        if (!input.hasAttribute('data-listener-attached')) {
            input.addEventListener('input', calculateTotals);
            input.addEventListener('change', calculateTotals);
            input.setAttribute('data-listener-attached', 'true');
        }
    });
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    attachCalculators();
    attachBudgetCategoryCreateListeners();
    calculateTotals();
});

// Also run immediately in case DOMContentLoaded already fired
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
        attachCalculators();
        attachBudgetCategoryCreateListeners();
        calculateTotals();
    });
} else {
    attachCalculators();
    attachBudgetCategoryCreateListeners();
    calculateTotals();
}
</script>

