<div class="container py-4">
    {% set page_actions %}
        <div class="page-header-actions d-flex align-items-center gap-2">
            <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/finances/reports" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Voltar aos Relatórios
            </a>
            <form method="get" action="{{ BASE_URL }}condominiums/{{ condominium.id }}/finances/reports/debug-quotas-payments" class="d-inline-flex align-items-center gap-2">
                <label for="year" class="form-label mb-0 small">Ano:</label>
                <input type="number" name="year" id="year" value="{{ year }}" min="2020" max="2030" class="form-control form-control-sm" style="width: 6rem;">
                <button type="submit" class="btn btn-outline-primary btn-sm">Aplicar</button>
            </form>
        </div>
    {% endset %}
    {% include 'blocks/page-header.html.twig' with {
        'title': 'Teste: Quotas pagas no ano ' ~ year,
        'actions': page_actions
    } %}

    <p class="text-muted small">
        Lista todos os pagamentos de quotas com data de pagamento em {{ year }} para o condomínio <strong>{{ condominium.name }}</strong>.
        Mostra o <strong>ano da quota</strong> (period_year) para despistar o Balancete (anos anteriores / adiantamentos).
    </p>

    {% set st = debug.summary_totals %}
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Resumo por tipo (conforme period_year)</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <p class="mb-0"><strong>Ano em curso ({{ year }}):</strong> <span class="text-primary">€{{ st.current|number_format(2, ',', '.') }}</span></p>
                </div>
                <div class="col-md-4">
                    <p class="mb-0"><strong>Anos anteriores (&lt; {{ year }}):</strong> <span class="text-warning">€{{ st.prior|number_format(2, ',', '.') }}</span></p>
                </div>
                <div class="col-md-4">
                    <p class="mb-0"><strong>Anos posteriores / adiantamentos (&gt; {{ year }}):</strong> <span class="text-info">€{{ st.future|number_format(2, ',', '.') }}</span></p>
                </div>
            </div>
            {% if debug.remaining_quotas_not_applied is defined and debug.remaining_quotas_not_applied > 0 %}
            <p class="mb-0 mt-2 small text-muted">Inclui <strong>saldos restantes (movimentos Quotas não aplicados):</strong> €{{ debug.remaining_quotas_not_applied|number_format(2, ',', '.') }} — valor recebido como quotas mas ainda não associado a nenhuma quota (ex.: ano da quota ainda não criado).</p>
            {% endif %}
            <p class="mb-0 mt-2 small text-muted">Total fee_payments no ano + saldos restantes Quotas: €{{ (st.current + st.prior + st.future)|number_format(2, ',', '.') }}</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Totais por ano da quota (period_year)</h5>
        </div>
        <div class="card-body">
            {% if debug.summary_by_period_year|length > 0 %}
            <table class="table table-sm table-bordered mb-0">
                <thead>
                    <tr>
                        <th>Ano da quota (period_year)</th>
                        <th class="text-end">Total (€)</th>
                    </tr>
                </thead>
                <tbody>
                    {% for py, total in debug.summary_by_period_year %}
                    <tr>
                        <td>{{ py }}</td>
                        <td class="text-end">€{{ total|number_format(2, ',', '.') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <p class="text-muted mb-0">Nenhum pagamento no ano {{ year }}.</p>
            {% endif %}
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Lista de movimentos (fee_payments em {{ year }})</h5>
        </div>
        <div class="card-body p-0">
            {% if debug.rows|length > 0 %}
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Data pagamento</th>
                            <th>Fração</th>
                            <th>Ano da quota (period_year)</th>
                            <th>Período</th>
                            <th class="text-end">Valor (€)</th>
                            <th>Categoria (FT)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in debug.rows %}
                        <tr>
                            <td>{{ row.payment_date|date('d/m/Y') }}</td>
                            <td>{{ row.fraction_identifier }}</td>
                            <td>
                                {% set py = row.period_year ?? year %}
                                {% if py < year %}<span class="text-warning">{% endif %}
                                {% if py > year %}<span class="text-info">{% endif %}
                                {{ py }}
                                {% if py != year %}</span>{% endif %}
                            </td>
                            <td>{{ row.period_month ? (row.period_month ~ '/' ~ row.period_year) : (row.period_index ? 'Índice ' ~ row.period_index : '—') }}</td>
                            <td class="text-end">€{{ row.amount|number_format(2, ',', '.') }}</td>
                            <td><small>{{ row.ft_category|default('—') }}</small></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="text-muted p-3 mb-0">Nenhum pagamento de quotas com data de pagamento no ano {{ year }}.</p>
            {% endif %}
        </div>
    </div>
</div>
