<div class="m-dashboard">
    <h1 class="m-page-title"><i class="bi bi-house-heart m-page-title-icon"></i> Bem-vindo, {{ user.name }}</h1>

    {% if overdue_fees|length > 0 %}
    <section class="m-section">
        <div class="m-card m-alert-overdue">
            <h2 class="m-card-title"><i class="bi bi-exclamation-triangle-fill m-card-title-icon m-card-title-icon-danger"></i> Quotas em atraso</h2>
            <div class="m-overdue-header">
                <p class="m-overdue-total"><i class="bi bi-currency-euro"></i> Total em atraso: <strong>{{ total_overdue|number_format(2, ',', ' ') }} €</strong></p>
                {% if overdue_condominium_ibans|length > 0 %}
                <button type="button" class="m-btn m-btn-iban" data-toggle="iban" aria-expanded="false" aria-controls="m-overdue-iban-block"><i class="bi bi-bank2"></i> Ver IBAN</button>
                {% endif %}
            </div>
            <div id="m-overdue-iban-block" class="m-overdue-iban-block" hidden>
                {% for row in overdue_condominium_ibans %}
                {% if row.iban %}
                <div class="m-overdue-iban-item">
                    {% if overdue_condominium_ibans|length > 1 %}<span class="m-overdue-iban-label">{{ row.condominium_name }}:</span>{% endif %}
                    <div class="m-overdue-iban-row">
                        <code class="m-overdue-iban-code">{{ row.iban }}</code>
                        <button type="button" class="m-btn-copy-iban" data-iban="{{ row.iban }}" title="Copiar IBAN" aria-label="Copiar IBAN"><i class="bi bi-clipboard"></i></button>
                    </div>
                </div>
                {% endif %}
                {% endfor %}
            </div>
            <details class="m-overdue-details">
                <summary class="m-overdue-summary"><i class="bi bi-list-ul"></i> Ver lista de quotas em atraso ({{ overdue_fees|length }})</summary>
                <ul class="m-list">
                    {% for fee in overdue_fees %}
                    <li class="m-list-item"><i class="bi bi-currency-euro m-list-icon"></i> {{ fee.condominium_name }}{% if fee.fraction_identifier %} – {{ fee.fraction_identifier }}{% endif %}: {{ fee.period_display }} – {{ fee.remaining|number_format(2, ',', ' ') }} €</li>
                    {% endfor %}
                </ul>
            </details>
        </div>
    </section>
    {% endif %}

    {% if pending_fees|length > 0 %}
    <section class="m-section">
        <div class="m-card m-alert-pending">
            <h2 class="m-card-title"><i class="bi bi-clock-history m-card-title-icon m-card-title-icon-warning"></i> Quotas pendentes</h2>
            <p class="m-overdue-total"><i class="bi bi-currency-euro"></i> Total pendente: <strong>{{ total_pending|number_format(2, ',', ' ') }} €</strong></p>
            <details class="m-overdue-details">
                <summary class="m-overdue-summary"><i class="bi bi-list-ul"></i> Ver lista de quotas pendentes ({{ pending_fees|length }})</summary>
                <ul class="m-list">
                    {% for fee in pending_fees %}
                    <li class="m-list-item"><i class="bi bi-calendar-check m-list-icon"></i> {{ fee.condominium_name }}{% if fee.fraction_identifier %} – {{ fee.fraction_identifier }}{% endif %}: {{ fee.period_display }} – {{ fee.remaining|number_format(2, ',', ' ') }} € <span class="m-badge m-badge-due">Venc. {{ fee.due_date|date('d/m/Y') }}</span></li>
                    {% endfor %}
                </ul>
            </details>
            <a href="{{ BASE_URL }}condominiums/{{ pending_fees[0].condominium_id }}/fees" class="m-link-block"><i class="bi bi-wallet2"></i> Ver quotas e pagar</a>
        </div>
    </section>
    {% endif %}

    {% if fraction_balances|length > 0 %}
    <section class="m-section">
        <div class="m-card m-alert-balance">
            <h2 class="m-card-title"><i class="bi bi-wallet2 m-card-title-icon m-card-title-icon-success"></i> Saldo em conta</h2>
            <ul class="m-list">
                {% for row in fraction_balances %}
                <li class="m-list-item"><i class="bi bi-piggy-bank m-list-icon"></i> {{ row.condominium_name }}{% if row.fraction_identifier %} – {{ row.fraction_identifier }}{% endif %}: {{ row.balance|number_format(2, ',', ' ') }} €</li>
                {% endfor %}
            </ul>
        </div>
    </section>
    {% endif %}

    {% if unread_notifications|length > 0 %}
    <section class="m-section">
        <h2 class="m-card-title"><i class="bi bi-bell-fill m-card-title-icon m-card-title-icon-primary"></i> Notificações não lidas</h2>
        <div class="m-notifications-list">
            {% for notification in unread_notifications %}
                {% set notification_icon = 'bi-bell' %}
                {% set notification_color_class = 'm-notif-primary' %}
                {% if notification.type == 'occurrence' %}
                    {% set notification_icon = 'bi-exclamation-triangle' %}
                    {% set notification_color_class = 'm-notif-warning' %}
                {% elseif notification.type == 'assembly' %}
                    {% set notification_icon = 'bi-people' %}
                    {% set notification_color_class = 'm-notif-info' %}
                {% elseif notification.type == 'fee_overdue' %}
                    {% set notification_icon = 'bi-currency-euro' %}
                    {% set notification_color_class = 'm-notif-danger' %}
                {% elseif notification.type == 'message' or notification.source_type == 'message' %}
                    {% set notification_icon = 'bi-envelope' %}
                    {% set notification_color_class = 'm-notif-primary' %}
                {% elseif notification.type == 'occurrence_comment' %}
                    {% set notification_icon = 'bi-chat' %}
                    {% set notification_color_class = 'm-notif-success' %}
                {% endif %}

                <div class="m-card m-notification-card m-notification-unread {{ notification_color_class }}">
                    <div class="m-notification-inner">
                        <div class="m-notification-icon {{ notification_color_class }}">
                            <i class="bi {{ notification_icon }}"></i>
                        </div>
                        <div class="m-notification-body">
                            <div class="m-notification-row">
                                <h2 class="m-notification-title m-notification-title-unread">{{ notification.title }}</h2>
                                {% if notification.type == 'occurrence' and notification.priority %}
                                    {% set priority_class = 'm-priority-' ~ (notification.priority|default('medium')) %}
                                    <span class="m-badge {{ priority_class }}">{{ notification.priority == 'urgent' ? 'Urgente' : (notification.priority == 'high' ? 'Alta' : (notification.priority == 'medium' ? 'Média' : 'Baixa')) }}</span>
                                {% endif %}
                            </div>
                            <p class="m-notification-message">{{ notification.message }}</p>
                            <div class="m-notification-meta">
                                <i class="bi bi-clock"></i>
                                {% set created_at = notification.created_at|date('U') %}
                                {% set now = 'now'|date('U') %}
                                {% set diff = now - created_at %}
                                {% if diff < 60 %}
                                    agora
                                {% elseif diff < 3600 %}
                                    há {{ (diff / 60)|round }} minutos
                                {% elseif diff < 86400 %}
                                    há {{ (diff / 3600)|round }} horas
                                {% elseif diff < 604800 %}
                                    há {{ (diff / 86400)|round }} dias
                                {% elseif diff < 2592000 %}
                                    há {{ (diff / 604800)|round }} semanas
                                {% else %}
                                    há {{ (diff / 2592000)|round }} meses
                                {% endif %}
                            </div>
                            <div class="m-notification-actions">
                                <a href="{{ BASE_URL }}m/notifications/show?id={{ notification.id|e('url') }}" class="m-btn m-btn-sm m-btn-ver-mais" title="Ver mais"><i class="bi bi-envelope"></i> Ver mais</a>
                                <form method="POST" action="{{ BASE_URL }}m/notifications/{{ notification.id|e('url') }}/mark-read" class="m-notification-form-inline">
                                    <button type="submit" class="m-btn m-btn-sm m-btn-success" title="Marcar como lida"><i class="bi bi-check"></i></button>
                                </form>
                                {% if notification.source_type == 'notification' %}
                                <form method="POST" action="{{ BASE_URL }}m/notifications/{{ notification.id|e('url') }}/delete" class="m-notification-form-inline" onsubmit="return confirm('Eliminar esta notificação?');">
                                    <button type="submit" class="m-btn m-btn-sm m-btn-danger" title="Eliminar"><i class="bi bi-trash"></i></button>
                                </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <a href="{{ BASE_URL }}m/notifications" class="m-link-block m-notifications-ver-mais"><i class="bi bi-chevron-right"></i> Ver mais</a>
    </section>
    {% endif %}

    {% if unread_messages_count > 0 %}
    <section class="m-section">
        <h2 class="m-card-title"><i class="bi bi-envelope-fill m-card-title-icon m-card-title-icon-primary"></i> Mensagens por ler</h2>
        {% if unread_messages|length > 0 %}
        <div class="m-notifications-list">
            {% for message in unread_messages %}
                <div class="m-card m-notification-card m-notification-unread m-notif-primary">
                    <div class="m-notification-inner">
                        <div class="m-notification-icon m-notif-primary">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <div class="m-notification-body">
                            <div class="m-notification-row">
                                <h2 class="m-notification-title m-notification-title-unread">{{ message.subject|default('Mensagem') }}</h2>
                            </div>
                            <p class="m-notification-message">{{ message.message|striptags|slice(0, 120) }}{% if message.message|striptags|length > 120 %}...{% endif %}</p>
                            <div class="m-notification-meta">
                                <i class="bi bi-person"></i> {{ message.sender_name|default('Sistema') }}
                                {% if message.condominium_name %} · {{ message.condominium_name }}{% endif %}
                            </div>
                            <div class="m-notification-meta">
                                <i class="bi bi-clock"></i>
                                {% set created_at = message.created_at|date('U') %}
                                {% set now = 'now'|date('U') %}
                                {% set diff = now - created_at %}
                                {% if diff < 60 %}
                                    agora
                                {% elseif diff < 3600 %}
                                    há {{ (diff / 60)|round }} minutos
                                {% elseif diff < 86400 %}
                                    há {{ (diff / 3600)|round }} horas
                                {% elseif diff < 604800 %}
                                    há {{ (diff / 86400)|round }} dias
                                {% elseif diff < 2592000 %}
                                    há {{ (diff / 604800)|round }} semanas
                                {% else %}
                                    há {{ (diff / 2592000)|round }} meses
                                {% endif %}
                            </div>
                            <div class="m-notification-actions">
                                <a href="{{ BASE_URL }}m/messages/show?id={{ message.id }}" class="m-btn m-btn-sm m-btn-ver-mais" title="Ver mais"><i class="bi bi-envelope-open"></i> Ver mais</a>
                                <form method="POST" action="{{ BASE_URL }}m/messages/{{ message.id }}/mark-read" class="m-notification-form-inline">
                                    <button type="submit" class="m-btn m-btn-sm m-btn-success" title="Marcar como lida"><i class="bi bi-check"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        {% else %}
        <p class="m-card-body">{{ unread_messages_count }} mensagem(ns) por ler.</p>
        {% endif %}
        <a href="{{ BASE_URL }}m/messages" class="m-link-block m-notifications-ver-mais"><i class="bi bi-chevron-right"></i> Ver mais</a>
    </section>
    {% endif %}

    <section class="m-section">
        <div class="m-card m-alert-receipts">
            <h2 class="m-card-title"><i class="bi bi-receipt m-card-title-icon m-card-title-icon-muted"></i> Últimos recibos</h2>
            {% if last_receipts|length > 0 %}
            <ul class="m-list">
                {% for r in last_receipts %}
                <li class="m-list-item">
                    <i class="bi bi-file-earmark-pdf m-list-icon"></i> {{ r.condominium_name }} – {{ r.period_display }}
                    <a href="{{ BASE_URL }}condominiums/{{ r.condominium_id }}/receipts/{{ r.id }}/download" class="m-link-block"><i class="bi bi-download"></i> Descarregar</a>
                </li>
                {% endfor %}
            </ul>
            <a href="{{ BASE_URL }}m/receipts" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver todos os recibos</a>
            {% else %}
            <p class="m-empty"><i class="bi bi-inbox"></i> Sem recibos.</p>
            <a href="{{ BASE_URL }}m/receipts" class="m-link-block"><i class="bi bi-receipt"></i> Os meus recibos</a>
            {% endif %}
        </div>
    </section>

    {% if future_reservations|length > 0 %}
    <section class="m-section">
        <div class="m-card">
            <h2 class="m-card-title"><i class="bi bi-calendar-event m-card-title-icon m-card-title-icon-info"></i> Marcações de espaços (futuras)</h2>
            <ul class="m-list">
                {% for res in future_reservations %}
                <li class="m-list-item"><i class="bi bi-calendar3 m-list-icon"></i> {{ res.space_name }} – {{ res.start_date|date('d/m/Y') }} – {{ res.condominium_name }}</li>
                {% endfor %}
            </ul>
            <a href="{{ BASE_URL }}m/reservations" class="m-link-block"><i class="bi bi-chevron-right"></i> Ver reservas</a>
        </div>
    </section>
    {% endif %}

    {% if first_condominium_id %}
    <section class="m-section">
        <a href="{{ BASE_URL }}condominiums/{{ first_condominium_id }}/occurrences/create" class="m-btn-report"><i class="bi bi-plus-circle"></i> Reportar ocorrência</a>
    </section>
    {% endif %}
</div>

<script>
(function () {
  var btn = document.querySelector('.m-btn-iban');
  var block = document.getElementById('m-overdue-iban-block');
  if (btn && block) {
    btn.addEventListener('click', function () {
      var isHidden = block.hasAttribute('hidden');
      block.toggleAttribute('hidden', !isHidden);
      btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      var icon = btn.querySelector('i.bi');
      if (isHidden) {
        btn.innerHTML = '<i class="bi bi-bank2"></i> Ocultar IBAN';
      } else {
        btn.innerHTML = '<i class="bi bi-bank2"></i> Ver IBAN';
      }
    });
  }
  document.querySelectorAll('.m-btn-copy-iban').forEach(function (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var iban = (this.getAttribute('data-iban') || '').replace(/\s/g, '');
      if (!iban) return;
      var icon = this.querySelector('i.bi');
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(iban).then(function () {
          if (icon) { icon.classList.remove('bi-clipboard'); icon.classList.add('bi-clipboard-check'); }
          copyBtn.setAttribute('title', 'Copiado!');
          copyBtn.setAttribute('aria-label', 'Copiado!');
          setTimeout(function () {
            if (icon) { icon.classList.remove('bi-clipboard-check'); icon.classList.add('bi-clipboard'); }
            copyBtn.setAttribute('title', 'Copiar IBAN');
            copyBtn.setAttribute('aria-label', 'Copiar IBAN');
          }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = iban;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
          if (icon) { icon.classList.remove('bi-clipboard'); icon.classList.add('bi-clipboard-check'); }
          copyBtn.setAttribute('title', 'Copiado!');
          setTimeout(function () {
            if (icon) { icon.classList.remove('bi-clipboard-check'); icon.classList.add('bi-clipboard'); }
            copyBtn.setAttribute('title', 'Copiar IBAN');
          }, 2000);
        } finally {
          document.body.removeChild(ta);
        }
      }
    });
  });
})();
</script>
