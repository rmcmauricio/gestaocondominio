<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h2 class="mb-2 mb-md-0">{{ condominium.name }}</h2>
        <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-md-auto align-items-start align-items-md-center">
            {% include 'blocks/quick-actions.html.twig' %}
            {% set can_edit = (current_condominium_role == 'admin' or user.role == 'super_admin') and (demo_profile != 'condomino') %}
            {% if can_edit %}
            <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/assign-admin" class="btn btn-outline-warning">
                <i class="bi bi-shield-check"></i> Designar Administradores
            </a>
            <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/customize" class="btn btn-outline-info">
                <i class="bi bi-palette"></i> Personalizar
            </a>
            <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/edit" class="btn btn-outline-primary">
                <i class="bi bi-pencil"></i> Editar
            </a>
            {% endif %}
            <a href="{{ BASE_URL }}dashboard" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    {% if error %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ error }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {% endif %}

    {% if success %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{ success }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {% endif %}

    {% if show_setup_wizard_banner|default(false) and can_edit|default(false) %}
    <div class="alert alert-info alert-dismissible fade show d-flex align-items-center justify-content-between flex-wrap gap-2" role="alert">
        <span><i class="bi bi-magic"></i> {% if setup_wizard_complete|default(false) %}Pode retomar o assistente de configuração para completar quotas, orçamentos ou outros passos.{% else %}A configuração inicial do condomínio ainda não está concluída.{% endif %}</span>
        <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/setup-wizard" class="btn btn-sm btn-info">{% if setup_wizard_complete|default(false) %}Retomar assistente de configuração{% else %}Continuar configuração{% endif %}</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {% endif %}

    <div class="row g-3">
        <div class="col-12">
            <div class="row g-3">
                <!-- Informações do Condomínio -->
                <div class="col-12 col-lg-6">
                    <div class="card shadow-sm mb-4 h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">Informações do Condomínio</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <strong>Morada:</strong><br>
                                {{ condominium.address }}<br>
                                {% if condominium.postal_code %}{{ condominium.postal_code }} {% endif %}{{ condominium.city }}
                                {% if condominium.district %}, {{ condominium.district }}{% endif %}
                            </div>
                            <div class="mb-3">
                                <strong>Contactos:</strong><br>
                                {% if condominium.phone %}<i class="bi bi-telephone"></i> {{ condominium.phone }}<br>{% endif %}
                                {% if condominium.email %}<i class="bi bi-envelope"></i> {{ condominium.email }}<br>{% endif %}
                                {% if condominium.nif %}<i class="bi bi-card-text"></i> NIF: {{ condominium.nif }}{% endif %}
                            </div>
                            {% if main_account_iban %}
                            <div class="mb-3">
                                <strong><i class="bi bi-bank"></i> IBAN (Conta Principal):</strong><br>
                                <code class="text-primary">{{ main_account_iban }}</code>
                            </div>
                            {% elseif condominium.iban %}
                            <div class="mb-3">
                                <strong><i class="bi bi-bank"></i> IBAN:</strong><br>
                                <code class="text-primary">{{ condominium.iban }}</code>
                            </div>
                            {% endif %}
                            {% if condominium.notes %}
                            <div class="mb-3">
                                <strong>Notas:</strong><br>
                                <p class="mb-0">{{ condominium.notes }}</p>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Contas Bancárias e Caixa -->
                {% if current_condominium_role == 'admin' %}
                <div class="col-12 col-lg-6">
                    {% if bank_accounts %}
                    <div class="card shadow-sm mb-4 h-100 bank-accounts-summary-card">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">Contas Bancárias e Caixa</h5>
                        </div>
                        <div class="card-body">
                            <div class="bank-accounts-list">
                                {% for account in bank_accounts %}
                                <div class="bank-account-item">
                                    <div class="bank-account-header">
                                        <strong class="bank-account-name">{{ account.name }}</strong>
                                        {% set account_balance = account.current_balance|default(0) %}
                                        <strong class="bank-account-balance {% if account_balance >= 0 %}text-success{% else %}text-danger{% endif %}">
                                            €{{ account_balance|number_format(2, ',', '.') }}
                                        </strong>
                                    </div>
                                    <small class="text-muted d-block mt-1">{{ account.bank_name|default('-') }}</small>
                                </div>
                                {% if not loop.last %}
                                <hr class="my-2">
                                {% endif %}
                                {% endfor %}
                                
                                <hr class="my-3">
                                
                                <div class="bank-account-item bank-account-total">
                                    <div class="bank-account-header">
                                        <strong class="bank-account-name">Total:</strong>
                                        <strong class="bank-account-balance {% if stats.total_bank_balance >= 0 %}text-success{% else %}text-danger{% endif %}">
                                            €{{ stats.total_bank_balance|number_format(2, ',', '.') }}
                                        </strong>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-3">
                                <a href="{{ BASE_URL }}condominiums/{{ condominium.id }}/bank-accounts" class="btn btn-sm btn-outline-info w-100">
                                    <i class="bi bi-bank"></i> Gerir Contas
                                </a>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
            </div>

            <!-- Estatísticas -->
            <div class="row g-3 mt-4">
                <div class="col-12">
                    <div class="card shadow-sm mb-4">
                        <div class="card-header">
                            <h6 class="mb-0">Estatísticas</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Frações</div>
                                        <div class="h5 mb-0">{{ condominium.active_fractions_count|default(condominium.total_fractions|default(0)) }}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Condóminos</div>
                                        <div class="h5 mb-0">{{ stats.total_residents }}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Conta à Ordem</div>
                                        <div class="h5 mb-0 {% if stats.current_account_balance >= 0 %}text-success{% else %}text-danger{% endif %}">
                                            €{{ stats.current_account_balance|number_format(2, ',', '.') }}
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Saldo Total</div>
                                        <div class="h5 mb-0 {% if stats.total_bank_balance >= 0 %}text-primary{% else %}text-danger{% endif %}">
                                            €{{ stats.total_bank_balance|number_format(2, ',', '.') }}
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Quotas Pendentes</div>
                                        <div class="h5 mb-0 text-warning">€{{ stats.pending_fees_amount|number_format(2, ',', '.') }}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Quotas Pagas</div>
                                        <div class="h5 mb-0 text-success">€{{ stats.paid_fees_amount|number_format(2, ',', '.') }}</div>
                                    </div>
                                </div>
                                {% if stats.overdue_fees > 0 %}
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Em Atraso</div>
                                        <div class="h5 mb-0 text-danger">{{ stats.overdue_fees }}<br><small>(€{{ stats.overdue_fees_amount|number_format(2, ',', '.') }})</small></div>
                                    </div>
                                </div>
                                {% endif %}
                                {% if stats.open_occurrences > 0 %}
                                <div class="col-6 col-md-3">
                                    <div class="text-center">
                                        <div class="text-muted small">Ocorrências</div>
                                        <div class="h5 mb-0 text-info">{{ stats.open_occurrences }}</div>
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Condóminos: uma linha por fração; admin só aparece na linha da fração a que está associado -->
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Condóminos ({{ stats.total_residents }})</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th>Fração</th>
                                    <th>Nome</th>
                                    <th>Email</th>
                                    <th>Telefone</th>
                                    <th>Tipologia</th>
                                    <th>Permilagem</th>
                                    {% if can_edit %}
                                    <th class="text-end">Ações</th>
                                    {% endif %}
                                </tr>
                            </thead>
                            <tbody>
                                {% for row in condominium_users %}
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">{{ row.fraction_identifier }}</span>
                                    </td>
                                    <td>
                                        {% for person in row.residents %}
                                        <div class="{% if not loop.first %}mt-1{% endif %}">
                                            <strong>{{ person.name }}</strong>
                                            {% if person.role %}
                                            <span class="badge ms-1
                                                {% if person.role == 'admin' %}bg-danger
                                                {% elseif person.role == 'proprietario' %}bg-primary
                                                {% elseif person.role == 'arrendatario' %}bg-info
                                                {% else %}bg-secondary{% endif %}" style="font-size: 0.65rem;">
                                                {{ person.role|title }}
                                            </span>
                                            {% endif %}
                                            {% if person.is_primary %}
                                            <span class="badge bg-success ms-1" style="font-size: 0.65rem;">Principal</span>
                                            {% endif %}
                                        </div>
                                        {% endfor %}
                                    </td>
                                    <td>{{ row.email }}</td>
                                    <td>{{ row.phone|default('-') }}</td>
                                    <td>
                                        {% if row.typology %}
                                        {{ row.typology }}
                                        {% else %}
                                        <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if row.permillage is defined and row.permillage is not null %}
                                        {{ row.permillage|number_format(0, '', '') }}‰
                                        {% else %}
                                        <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    {% if can_edit %}
                                    <td class="text-end">
                                        {% if row.pending_invitation_id and row.email != '-' %}
                                        <form method="POST" action="{{ BASE_URL }}condominiums/{{ condominium.id }}/invitations/{{ row.pending_invitation_id }}/resend" class="d-inline">
                                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Reenviar convite por email" data-confirm="Reenviar o convite por email?">
                                                <i class="bi bi-envelope-arrow-up"></i> Reenviar convite
                                            </button>
                                        </form>
                                        {% endif %}
                                    </td>
                                    {% endif %}
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Mapa de Quotas - Full Width -->
        {% include 'blocks/fees-map.html.twig' %}
    </div>
</div>

<!-- Modal e Script para Detalhes da Quota -->
{% include 'blocks/fees-map-modal.html.twig' %}


