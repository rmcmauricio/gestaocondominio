{% if is_mobile|default(false) %}
{# Versão mobile: mesmo conteúdo via partial, layout mobile #}
<div class="m-dashboard">
    <h1 class="m-page-title"><i class="bi bi-house-heart m-page-title-icon"></i> Bem-vindo, {{ user.name }}</h1>
    {% include 'blocks/dashboard-condomino-content.html.twig' with { 'dashboard_theme': 'mobile' } %}
</div>
<script>
(function () {
  var btn = document.querySelector('.m-btn-iban');
  var block = document.getElementById('m-overdue-iban-block');
  if (btn && block) {
    btn.addEventListener('click', function () {
      var isHidden = block.hasAttribute('hidden');
      block.toggleAttribute('hidden', !isHidden);
      btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      if (isHidden) {
        btn.innerHTML = '<i class="bi bi-bank2"></i> Ocultar IBAN';
      } else {
        btn.innerHTML = '<i class="bi bi-bank2"></i> Ver IBAN';
      }
    });
  }
  document.querySelectorAll('.m-btn-copy-iban').forEach(function (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var iban = (this.getAttribute('data-iban') || '').replace(/\s/g, '');
      if (!iban) return;
      var icon = copyBtn.querySelector('i.bi');
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(iban).then(function () {
          if (icon) { icon.classList.remove('bi-clipboard'); icon.classList.add('bi-clipboard-check'); }
          copyBtn.setAttribute('title', 'Copiado!');
          copyBtn.setAttribute('aria-label', 'Copiado!');
          setTimeout(function () {
            if (icon) { icon.classList.remove('bi-clipboard-check'); icon.classList.add('bi-clipboard'); }
            copyBtn.setAttribute('title', 'Copiar IBAN');
            copyBtn.setAttribute('aria-label', 'Copiar IBAN');
          }, 2000);
        });
      } else {
        var ta = document.createElement('textarea');
        ta.value = iban;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
          if (icon) { icon.classList.remove('bi-clipboard'); icon.classList.add('bi-clipboard-check'); }
          copyBtn.setAttribute('title', 'Copiado!');
          setTimeout(function () {
            if (icon) { icon.classList.remove('bi-clipboard-check'); icon.classList.add('bi-clipboard'); }
            copyBtn.setAttribute('title', 'Copiar IBAN');
          }, 2000);
        } finally {
          document.body.removeChild(ta);
        }
      }
    });
  });
})();
</script>
{% else %}
{# Versão completa #}
<div class="container mt-4">
    <input type="hidden" id="csrf_token" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" id="base_url" value="{{ BASE_URL }}">
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info border-0 shadow-sm mb-4 welcome-banner">
                <div class="d-flex align-items-center">
                    <div class="me-3">
                        <i class="bi bi-person-circle welcome-banner-icon"></i>
                    </div>
                    <div>
                        <h4 class="mb-1">Bem-vindo, {{ user.name }}!</h4>
                        <p class="mb-0 welcome-banner-text">Está a visualizar o seu painel de condómino.</p>
                    </div>
                </div>
            </div>

            {% if pending_invitations_for_user is defined and pending_invitations_for_user|length > 0 %}
            <div class="alert alert-warning border-0 shadow-sm mb-4">
                <h5 class="mb-3"><i class="bi bi-envelope-exclamation"></i> Convites pendentes para condomínio</h5>
                <p class="mb-3">Foi convidado para as seguintes frações. Aceite o convite para ter acesso ao condomínio.</p>
                <ul class="list-group list-group-flush mb-0">
                    {% for inv in pending_invitations_for_user %}
                    <li class="list-group-item d-flex align-items-center justify-content-between flex-wrap gap-2 bg-transparent border-0 px-0">
                        <span>
                            <strong>{{ inv.condominium_name }}</strong>
                            {% if inv.fraction_identifier %}<span class="text-muted"> – Fração {{ inv.fraction_identifier }}</span>{% endif %}
                            <br><small class="text-muted">Convite enviado em {{ inv.created_at|date('d/m/Y H:i') }}</small>
                        </span>
                        <a href="{{ BASE_URL }}invitation/accept?token={{ inv.token|e('url') }}" class="btn btn-success btn-sm">
                            <i class="bi bi-check-circle"></i> Aceitar convite
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="mb-0">Painel Condómino</h1>
                {% include 'blocks/help-button.html.twig' with {'section': 'dashboard', 'title': 'Ajuda com Dashboard', 'show_text': false} %}
            </div>

            {% include 'blocks/dashboard-condomino-content.html.twig' with { 'dashboard_theme': 'full' } %}
        </div>
    </div>
</div>

<script>
(function () {
  var block = document.getElementById('dashboard-overdue-iban');
  if (block) {
    var btn = document.querySelector('[data-bs-target="#dashboard-overdue-iban"]');
    if (btn) {
      btn.addEventListener('click', function () {
        var icon = btn.querySelector('i.bi');
        if (block.classList.contains('show')) {
          if (icon) btn.innerHTML = '<i class="bi bi-bank2"></i> Ver IBAN';
        } else {
          if (icon) btn.innerHTML = '<i class="bi bi-bank2"></i> Ocultar IBAN';
        }
      });
    }
  }
  document.querySelectorAll('.btn-copy-iban').forEach(function (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var iban = (this.getAttribute('data-iban') || '').replace(/\s/g, '');
      if (!iban) return;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(iban).then(function () {
          var icon = copyBtn.querySelector('i.bi');
          if (icon) { icon.classList.remove('bi-clipboard'); icon.classList.add('bi-clipboard-check'); }
          copyBtn.setAttribute('title', 'Copiado!');
          setTimeout(function () {
            if (icon) { icon.classList.remove('bi-clipboard-check'); icon.classList.add('bi-clipboard'); }
            copyBtn.setAttribute('title', 'Copiar IBAN');
          }, 2000);
        });
      }
    });
  });
})();
</script>
{% endif %}
