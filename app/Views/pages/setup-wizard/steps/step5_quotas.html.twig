<h5 class="mb-3">{{ page.t.step_5_title|default('Quotas') }}</h5>
<p class="text-muted">{{ page.t.step_5_help|default('Gere as quotas anuais ou extras abaixo, ou continue para o próximo passo.') }}</p>

{# Mapa de quotas (sem card colapsado) quando já existem quotas #}
{% if wizard_has_fees_map|default(false) %}
<div class="row g-0 mb-4">
    {% include 'blocks/fees-map.html.twig' with {
        'condominium': condominium,
        'fractions': fees_map_fractions|default(fractions),
        'fees_map': fees_map|default([]),
        'fee_period_labels': fee_period_labels|default({}),
        'month_names': month_names|default({}),
        'selected_fees_year': selected_fees_year|default('now'|date('Y')),
        'available_years': available_years|default([]),
        'fees_map_form_action': BASE_URL ~ 'condominiums/' ~ wizard_condominium_id ~ '/setup-wizard',
        'wizard_step': 5,
        'open_fee_details_in_new_tab': true,
        'fees_details_url_base': BASE_URL ~ 'condominiums/' ~ wizard_condominium_id ~ '/fees?year=' ~ (selected_fees_year|default('now'|date('Y')))
    } %}
</div>
{% endif %}

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h6 class="mb-0">Gerar Quotas</h6>
    </div>
    <div class="card-body">
        {% include 'blocks/generate-fees-style.html.twig' %}
        <form method="POST" action="{{ BASE_URL }}condominiums/{{ wizard_condominium_id }}/fees/generate" id="generateFeesForm" class="generate-fees-form">
            {% include 'blocks/generate-fees-form.html.twig' with {
                'condominium': { 'id': wizard_condominium_id },
                'fractions': fractions|default([]),
                'current_year': current_year|default('now'|date('Y')),
                'csrf_token': csrf_token,
                'redirect_url': BASE_URL ~ 'condominiums/' ~ wizard_condominium_id ~ '/setup-wizard?step=5'
            } %}
            <div class="d-flex flex-wrap gap-2 justify-content-end mt-3">
                <button type="button" class="btn btn-secondary" id="btnBack" style="display: none;">Voltar</button>
                <button type="button" class="btn btn-primary" id="btnNext">Continuar</button>
                <button type="submit" class="btn btn-primary" id="btnSubmit" style="display: none;">Gerar Quotas</button>
            </div>
        </form>
        {% include 'blocks/generate-fees-script.html.twig' with {
            'condominium_id': wizard_condominium_id,
            'base_url': BASE_URL,
            'modal_id': '',
            'form_id': 'generateFeesForm'
        } %}
    </div>
</div>

<form method="post" action="{{ BASE_URL }}condominiums/{{ wizard_condominium_id }}/setup-wizard/step/5" class="mt-3">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <div class="d-flex flex-wrap gap-2">
        <a href="{{ BASE_URL }}condominiums/{{ wizard_condominium_id }}/fees" class="btn btn-outline-primary" target="_blank">Abrir página de Quotas</a>
        <button type="submit" class="btn btn-primary">Seguinte passo</button>
        <button type="submit" class="btn btn-outline-secondary" name="wizard_skip" value="1" formnovalidate>Saltar</button>
    </div>
</form>
